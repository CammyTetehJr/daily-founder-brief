ANTHROPIC_API_KEY=
TAVILY_API_KEY=
RESEND_API_KEY=

# email address the brief is sent FROM (must be on a Resend-verified domain)
FROM_EMAIL=

# email address to seed as the demo user (run `npm run seed`)
SEED_USER_EMAIL=

# Optional: bearer token for the Peec AI MCP server.
# When set, the agent gains access to Peec AI's brand-visibility tools
# (list_brands, get_brand_report, list_chats, etc.) via Anthropic's MCP connector.
# Prefer the OAuth flow at /api/auth/peec/start - that token wins over this one.
PEEC_MCP_TOKEN=

# Pin the Peec AI project the agent should use (otherwise it picks
# heuristically). Find it under app.peec.ai - the project ID typically
# starts with "or_". Recommended: the project where you've added all
# tracked competitors as brands.
PEEC_PROJECT_ID=

# Google Cloud Vertex AI (Gemini multimodal visual diff).
# Auth uses Application Default Credentials - run `gcloud auth application-default login`.
# Required when the agent's `visual_check` tool is invoked.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Optional override; defaults to gemini-2.5-flash
GEMINI_MODEL=

# Optional: Gradium TTS for voice version of the brief.
# When set, the pipeline generates a wav file at data/audio/<brief_id>.wav
# after composing, in parallel with email send.
GRADIUM_API_KEY=
# Optional voice override; defaults to YTpq7expH9539ERJ (Emma, US English female)
GRADIUM_VOICE_ID=
